APP_NAME=Fundrize
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL="http://fundrize.test"

# --- Tenancy & Domain Configuration ---
TENANCY_BASE_DOMAIN=fundrize.test
TENANCY_SUPERADMIN_DOMAIN=superadmin.fundrize.test
TENANCY_APP_DOMAIN=app.fundrize.test
SESSION_DOMAIN=.fundrize.test

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fn_saas
DB_USERNAME=root
DB_PASSWORD=

# --- Driver Configuration ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Mail Configuration ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Duitku Payment Gateway ---
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_SANDBOX=true

# --- WhatsApp & Notifications ---
STARSENDER_API_KEY=
SYSTEM_FEE_PERCENTAGE=2

# --- Maintenance & Billing info ---
MAINTENANCE_BANK=BSI
MAINTENANCE_ACCOUNT_NUMBER=
MAINTENANCE_ACCOUNT_NAME="PT. KAFILAH DIGITAL MANDIRI INDONESIA"

VITE_APP_NAME="${APP_NAME}"
